{
  "name": "arthropod-terrarium",
  "version": "0.6.0",
  "description": "Motor del Terrario Vivo: convierte proyectos en una colonia de artropodos como HTML estatico autocontenido.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "python3 motor/build_imperio.py",
    "build:personal": "python3 motor/build.py ../tierra/datos ../tierra/terrario.html",
    "verify": "node motor/verifica_app.js demo/index.html",
    "verify:personal": "node motor/verificar.js ../tierra/terrario.html",
    "todo": "npm run build && npm run verify",
    "build:clasico": "python3 motor/build.py ejemplo demo/clasico.html",
    "verify:clasico": "node motor/verificar.js demo/clasico.html"
  },
  "devDependencies": {
    "jsdom": "^24.1.0"
  }
}
